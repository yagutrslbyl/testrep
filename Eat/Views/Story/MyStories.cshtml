@model List<Eat.ViewModels.StoryVMs.StoryDashboardVM>

<main class="myst-main-container">

    <div class="myst-page-header">
        <h1>My Stories</h1>
        <div class="myst-header-stats">
            <span>
                @Model.Sum(s => s.Chapters.Count) Published Parts
            </span>
            <button class="myst-new-story-btn" onclick="location.href='@Url.Action("Create", "Story")'">
                <i class="fas fa-plus"></i> New Story
            </button>
        </div>
    </div>

    <!-- Tabs -->
    <div class="myst-tabs">
        <button class="myst-tab myst-active">Published</button>
        <button class="myst-tab">All stories</button>
        <button class="myst-tab">Series</button>
    </div>

    <!-- Stories Grid -->
    <div class="myst-stories-grid">

        <div class="myst-stories-grid">

            @foreach (var story in Model)
            {
                var lastUpdate = story.Chapters
                .OrderByDescending(c => c.CreatedDate)
                .FirstOrDefault()?.CreatedDate;

                <div class="myst-story-card myst-featured">
                    <div class="myst-card-left">
                        <div class="myst-cover-wrapper">
                            <img src="~/uploads/stories/@story.CoverImageUrl"
                                 alt="Story Cover" class="myst-story-cover">
                        </div>

                        <div class="myst-story-info">
                            <h2 class="myst-story-title">
                                <a asp-controller="Story"
                                   asp-action="StoryDetails"
                                   asp-route-id="@story.Id"
                                   style="text-decoration:none; color:inherit;">
                                    @story.Title
                                </a>
                            </h2>

                            <p class="myst-story-meta">
                                @story.Chapters.Count Published Parts
                            </p>

                            <p class="myst-updated">
                                @(lastUpdate != null
                                                            ? "Updated " + lastUpdate.Value.ToString("dd MMM yyyy")
                                                            : "No chapters yet")
                        </p>

                            <div class="myst-stats-bar">
                                <span>
                                    <i class="fas fa-eye"></i>
                                    @story.Chapters.Sum(c => c.Views)
                                </span>

                                <span>
                                    <i class="fas fa-star"></i>
                                    @story.Chapters.Sum(c => c.Votes)
                                </span>

                                <span>
                                    <i class="fas fa-comment"></i>
                                    @story.Chapters.Sum(c => c.CommentsCount)
                                </span>
                            </div>

                            <div class="myst-action-buttons">
                                <form method="post" asp-action="StartChapter" asp-controller="Story" asp-route-id="@story.Id">
                                    <button type="submit" class="myst-continue-btn">
                                        Continue Writing
                                    </button>
                                </form>

                                <form method="post" asp-action="Delete" asp-controller="Story" asp-route-id="@story.Id"
                                      onsubmit="return confirm('Are you sure you want to delete this story?');">
                                    <button type="submit" class="myst-continue-btn">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                        }
        </div>

    </div>

    <!-- Promo Sidebar -->
    <aside class="myst-promo-sidebar">
        <div class="myst-promo-card">
            <h3>MAKING THE MOST OF WATTPAD</h3>
            <img src="https://images.unsplash.com/photo-1555066931-bf19c65fd1df?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                 alt="Creators Promo" class="myst-promo-image">
            <p>Getting started on Wattpad • Foundations for success • Community guidelines & safety • Building an audience</p>
            <a href="#" class="myst-promo-link">Visit Creators Hub →</a>
        </div>
    </aside>

</main>