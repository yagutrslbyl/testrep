@using Microsoft.AspNetCore.Identity
@using Eat.Models

@inject UserManager<AppUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wattpad | Home</title>

    <link rel="stylesheet" href="~/css/chapter-read.css">
    <link rel="stylesheet" href="~/css/notification.css" asp-append-version="true">

    <link rel="stylesheet" href="~/css/read-chapter.css" asp-append-version="true">

    <link rel="stylesheet" href="~/css/read-story.css" asp-append-version="true">

    <link rel="stylesheet" href="~/css/components.css">
    <link rel="stylesheet" href="~/css/create-story.css">
    <link rel="stylesheet" href="~/css/home.css">
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true">
    <link rel="stylesheet"
          href="~/css/mystories.css"
          asp-append-version="true" />
    
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/reset.css">
    <link rel="stylesheet" href="~/css/search.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/story-dashboard.css">
    <link rel="stylesheet" href="~/css/story-detail.css">
    <link rel="stylesheet" href="~/css/variables.css">
    <link rel="stylesheet" href="~/css/write-story.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/layout.css">

    <style>
        .profile {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #ff6b6b;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            font-weight: bold;
        }

        .profile-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }</style>


    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <header class="header">
        <div class="container header__content">

            <!-- LEFT -->
            <div class="header__left">
                <a asp-controller="Home" asp-action="Index" class="logo">StoryVerse</a>

                <nav class="nav">
                  
                    <a asp-controller="Home" asp-action="Community">Community</a>
                    <a asp-controller="Home" asp-action="Premium">Premium</a>
                </nav>
            </div>

            <!-- SEARCH -->
            <div class="header__search">
                @if (User.Identity.IsAuthenticated)
                {
                    <form asp-controller="Search" asp-action="Results" method="get">
                        <input type="text" name="query" placeholder="Search stories, writers..." />
                    </form>
                }
            </div>

            <!-- RIGHT -->

            <div class="header__right">

                @if (User.Identity.IsAuthenticated)
                {
                    <!-- Write -->
                    <div class="write-wrapper">
                        <button class="write-btn">Write ▾</button>
                        <div class="write-dropdown">
                            <a asp-controller="Story" asp-action="Create">➕ Create a new story</a>
                            <a asp-controller="Story" asp-action="MyStories">My Stories</a>
                            <hr>
                            <a href="#">Writer Resources</a>
                            <a href="#">Writing Contests</a>
                        </div>
                    </div>

                    <!-- Notification -->
                    <a asp-controller="Notification" asp-action="Index" class="notification">
                        🔔
                        @* <span class="badge">@ViewBag.NotificationCount</span> *@
                    </a>

                    <!-- Profile -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        var username = user?.UserName ?? "U";
                        var firstLetter = username.Substring(0, 1).ToUpper();

                        <div class="profile-wrapper">

                            <div class="profile">

                                @if (!string.IsNullOrEmpty(user?.ProfileImageUrl))
                                {
                                    <img src="~/uploads/profiles/@user.ProfileImageUrl" class="profile-img" />
                                }
                                else
                                {
                                    <span>@firstLetter</span>
                                }

                            </div>

                            <div class="dropdown">
                                <a asp-controller="Profile" asp-action="Index">My Profile</a>
                                <a asp-controller="Account" asp-action="Logout">Log Out</a>
                            </div>

                        </div>
                    }

                    @* <div class="profile-wrapper">
                        <div class="profile">
                            @User.Identity.Name.Substring(0, 1)
                        </div>
                        <div class="dropdown">
                            <a asp-controller="profile" asp-action="Index">My Profile</a>
                            <a asp-controller="Account" asp-action="Logout">Log Out</a>
                        </div>
                    </div> *@
                }
                else
                {
                    <a asp-controller="Account"
                       asp-action="Login"
                       style="
            padding:10px 22px;
            border-radius:25px;
            font-weight:600;
            text-decoration:none;
            margin-left:10px;
            display:inline-block;
            color:#ff6b00;
            border:2px solid #ff6b00;
            background-color:transparent;
            transition:0.3s;
       "
                       onmouseover="this.style.backgroundColor='#ff6b00';this.style.color='white';"
                       onmouseout="this.style.backgroundColor='transparent';this.style.color='#ff6b00';">
                        Login
                    </a>
                    <a asp-controller="Account"
                       asp-action="Register"
                       style="
            padding:10px 22px;
            border-radius:25px;
            font-weight:600;
            text-decoration:none;
            margin-left:10px;
            display:inline-block;
            color:white;
            background:linear-gradient(135deg,#ff6b00,#ff8c42);
            border:none;
            transition:0.3s;
       "
                       onmouseover="this.style.transform='translateY(-2px)';"
                       onmouseout="this.style.transform='translateY(0px)';">
                        Register
                    </a>
                }

            </div>

           
        </div>
    </header>
    <main class="container">

                <div>@RenderBody()</div>
    <footer class="footer">
        <div class="container footer__grid">

            <div class="footer__brand">
                <h3>Wattpad</h3>
                <p>Where stories live and writers grow.</p>
            </div>

            <div>
                <h4>Discover</h4>
                <a href="#">Browse</a>
                <a href="#">Premium</a>
                <a href="#">Writing Contests</a>
                <a asp-controller="Home" asp-action="Community">Community</a>
            </div>

            <div>
                <h4>Company</h4>
                <a href="#">About Us</a>
                <a href="#">Careers</a>
                <a href="#">Press</a>
                <a href="#">Contact</a>
            </div>

            <div>
                <h4>Support</h4>
                <a href="#">Help Center</a>
                <a href="#">Guidelines</a>
                <a href="#">Terms</a>
                <a href="#">Privacy Policy</a>
            </div>

        </div>

        <div class="footer__bottom">
            © 2026 Wattpad Clone. All rights reserved.
        </div>
    </footer>


    </main>

    <script src="~/js/carousel.js"></script>
    <script src="~/js/main.js"></script>
    <script src="~/js/profile.js"></script>
    <script src="~/js/write.js"></script>

</body>
</html>