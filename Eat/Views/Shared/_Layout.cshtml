<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wattpad | Home</title>

    <link rel="stylesheet" href="~/css/chapter-read.css">
    <link rel="stylesheet" href="~/css/components.css">
    <link rel="stylesheet" href="~/css/create-story.css">
    <link rel="stylesheet" href="~/css/home.css">
    <link rel="stylesheet" href="~/css/layout.css">
    <link rel="stylesheet" href="~/css/main.css">
    <link rel="stylesheet" href="~/css/mystories.css">
    <link rel="stylesheet" href="~/css/profile.css">
    <link rel="stylesheet" href="~/css/reset.css">
    <link rel="stylesheet" href="~/css/search.css">
    <link rel="stylesheet" href="~/css/story-dashboard.css">
    <link rel="stylesheet" href="~/css/story-detail.css">
    <link rel="stylesheet" href="~/css/variables.css">
    <link rel="stylesheet" href="~/css/write-story.css">



    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <header class="header">
        <div class="container header__content">

            <!-- LEFT -->
            <div class="header__left">
                <div class="logo">StoryVerse</div>

                <nav class="nav">
                    <a href="#">Browse</a>
                    <a href="#">Community</a>
                    <a href="#">Premium</a>
                </nav>
            </div>

            <!-- SEARCH -->
            <div class="header__search">
                <form action="search.html" method="GET">
                    <input type="text" name="q" placeholder="Search stories, writers..." />
                </form>
            </div>

            <!-- RIGHT -->
            <div class="header__right">

                <!-- Write -->
                <div class="write-wrapper">
                    <button class="write-btn">Write ▾</button>
                    <div class="write-dropdown">
                        <a href="create-story.html">➕ Create a new story</a>
                        <a href="mystories.html">My Stories</a>
                        <hr>
                        <a href="#">Writer Resources</a>
                        <a href="#">Writing Contests</a>
                    </div>
                </div>

                <!-- Notification -->
                <div class="notification">
                    🔔
                    <span class="badge">3</span>
                </div>


                <!-- Profile -->
                <div class="profile-wrapper">
                    <div class="profile">Q</div>
                    <div class="dropdown">
                        <a href="profile.html">My Profile</a>
                        <a href="#">Inbox</a>
                        <a href="#">Library</a>
                        <hr>
                        <a href="#">Settings</a>
                        <a href="#">Log Out</a>
                    </div>
                </div>

            </div>
        </div>
    </header>
    <main class="container">

                <div>@RenderBody()</div>
    <footer class="footer">
        <div class="container footer__grid">

            <div class="footer__brand">
                <h3>Wattpad</h3>
                <p>Where stories live and writers grow.</p>
            </div>

            <div>
                <h4>Discover</h4>
                <a href="#">Browse</a>
                <a href="#">Premium</a>
                <a href="#">Writing Contests</a>
                <a href="#">Community</a>
            </div>

            <div>
                <h4>Company</h4>
                <a href="#">About Us</a>
                <a href="#">Careers</a>
                <a href="#">Press</a>
                <a href="#">Contact</a>
            </div>

            <div>
                <h4>Support</h4>
                <a href="#">Help Center</a>
                <a href="#">Guidelines</a>
                <a href="#">Terms</a>
                <a href="#">Privacy Policy</a>
            </div>

        </div>

        <div class="footer__bottom">
            © 2026 Wattpad Clone. All rights reserved.
        </div>
    </footer>


    </main>

    <script src="~/js/carousel.js"></script>
    <script src="~/js/main.js"></script>
    <script src="~/js/profile.js"></script>
    <script src="~/js/write.js"></script>

</body>
</html>