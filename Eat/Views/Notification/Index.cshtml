@using Eat.ViewModels.Notification
@model NotificationViewModel




<div class="notifications-container">



    <section class="notification-section votes-section">
        <h2>Oylamalar</h2>

        @foreach (var vote in Model.Votes)
        {
            <div class="notification-item vote-item">
                
                <div class="notification-content">
                    <p>
                        <strong>@vote.User.UserName</strong> oyladı:
                        <span class="story-title">@vote.Story.Title</span>
                    </p>

                    <span class="time">@vote.Story.CreatedDate</span>
                </div>

                <div class="star-icon">★</div>

            </div>
        }
    </section>
    <section class="notification-section comments-section">
        <h2>Yorumlar</h2>

        @foreach (var comment in Model.Comments)
        {
            <div class="notification-item comment-item">

                <div class="notification-content">
                    <p>
                        <strong>@comment.User.UserName</strong> yorum yaptı:
                        <span class="story-title">@comment.Story.Title</span>
                    </p>

                    <p class="comment-preview">
                        @comment.Content
                    </p>

                    <span class="time">@comment.CreatedDate</span>

                </div>

            </div>
        }
    </section>

