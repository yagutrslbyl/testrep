    </section>

    <!-- RIGHT SIDE -->
    <aside class="search-right">
        <div class="premium-box">
            <h3>Go Premium</h3>
            <p>Read unlimited stories without ads and unlock exclusive content.</p>
            <button class="premium-btn">Upgrade Now</button>
        </div>
    </aside>

</main>

