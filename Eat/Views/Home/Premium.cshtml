@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Premium • StoryVerce</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #ffffff;
            color: #222222;
            line-height: 1.6;
        }

        header {
            background: #ff6200;
            color: white;
            padding: 1.2rem 0;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,0.12);
        }

        .header-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.9rem;
            font-weight: bold;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin-left: 1.8rem;
            font-weight: 500;
        }

            nav a:hover {
                text-decoration: underline;
                text-underline-offset: 4px;
            }

        .hero {
            background: linear-gradient(135deg, #ff6200 0%, #ff8c3d 100%);
            color: white;
            text-align: center;
            padding: 6rem 1rem 5rem;
        }

            .hero h1 {
                font-size: 3.4rem;
                margin-bottom: 1rem;
            }

            .hero p {
                font-size: 1.35rem;
                max-width: 780px;
                margin: 0 auto;
                opacity: 0.95;
            }

        .container {
            max-width: 1100px;
            margin: -3.5rem auto 0;
            padding: 0 20px;
        }

        .premium-intro {
            background: white;
            border-radius: 12px;
            padding: 2.5rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            margin-bottom: 3rem;
            text-align: center;
        }

            .premium-intro h2 {
                color: #ff6200;
                font-size: 2.2rem;
                margin-bottom: 1.2rem;
            }

            .premium-intro p {
                font-size: 1.15rem;
                margin-bottom: 1.4rem;
            }

        .plans {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
            margin: 3rem 0;
        }

        .plan-card {
            background: white;
            border: 2px solid #eee;
            border-radius: 12px;
            padding: 2rem;
            text-align: center;
            transition: all 0.25s;
        }

            .plan-card:hover {
                border-color: #ff6200;
                transform: translateY(-8px);
                box-shadow: 0 12px 30px rgba(255,98,0,0.15);
            }

            .plan-card.premium-plus {
                border-color: #ff6200;
                background: #fffaf5;
            }

        .plan-name {
            font-size: 1.8rem;
            font-weight: bold;
            color: #ff6200;
            margin-bottom: 1rem;
        }

        .price {
            font-size: 2.6rem;
            font-weight: 700;
            margin: 0.5rem 0 1.5rem;
            color: #222;
        }

            .price small {
                font-size: 1rem;
                opacity: 0.7;
            }

        .features {
            list-style: none;
            text-align: left;
            margin: 1.5rem 0 2rem;
        }

            .features li {
                margin: 1rem 0;
                font-size: 1.05rem;
                padding-left: 1.8rem;
                position: relative;
            }

                .features li::before {
                    content: "✔";
                    color: #ff6200;
                    position: absolute;
                    left: 0;
                    font-weight: bold;
                }

        .btn {
            display: inline-block;
            background: #ff6200;
            color: white;
            padding: 0.9rem 2rem;
            border-radius: 8px;
            text-decoration: none;
            font-size: 1.1rem;
            font-weight: 600;
            transition: background 0.2s;
        }

            .btn:hover {
                background: #e55a00;
            }

        .trial {
            margin-top: 1.5rem;
            font-size: 1.1rem;
            color: #555;
        }

        .comparison {
            background: #fff8f4;
            border-radius: 12px;
            padding: 2.5rem;
            margin: 4rem 0 3rem;
        }

            .comparison h2 {
                color: #ff6200;
                text-align: center;
                margin-bottom: 2rem;
            }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 1.2rem;
            text-align: center;
            border-bottom: 1px solid #eee;
        }

        th {
            background: #ff6200;
            color: white;
            font-weight: 600;
        }

        .check {
            color: #ff6200;
            font-size: 1.4rem;
            font-weight: bold;
        }

        footer {
            background: #222;
            color: #aaa;
            text-align: center;
            padding: 2.5rem;
            margin-top: 5rem;
        }

        @@media (max-width: 768px) {
            .hero h1

        {
            font-size: 2.6rem;
        }

        .hero p {
            font-size: 1.15rem;
        }

        .plans {
            grid-template-columns: 1fr;
        }

        }
    </style>
</head>
<body>

    <header>
        <div class="header-container">
            <div class="logo">StoryVerce</div>
            <nav>
                <a href="#">Keşfet</a>
                <a href="#">Community</a>
                <a href="#">Yaz</a>
                <a href="#">Premium</a>
            </nav>
        </div>
    </header>

    <section class="hero">
        <h1>StoryVerce Premium</h1>
        <p>Hikayelerini reklamsız oku, çevrimdışı keyfini çıkar ve daha fazlasını yaşa. StoryVerce'i sevdiğin gibi, ama çok daha güçlü.</p>
    </section>

    <div class="container">

        <div class="premium-intro">
            <h2>Neden Premium Olmalısın?</h2>
            <p>Reklamlar seni hikayeden koparıyor mu? Çevrimdışı okuyamamak canını sıkıyor mu? Favori StoryVerce Orijinallerini daha kolay açmak istiyorsun?</p>
            <p>Premium ile tüm bunlar tarih oluyor. Hem sen kazanıyorsun hem de StoryVerce'in kaliteli içerik üretmeye devam etmesi için destek oluyorsun.</p>
        </div>

        <div class="plans">

            <div class="plan-card">
                <div class="plan-name">Premium</div>
                <div class="price">₺29,99 <small>/ay</small></div>
                <ul class="features">
                    <li>Kesintisiz, reklamsız okuma</li>
                    <li>Çevrimdışı sınırsız hikaye</li>
                    <li>Her jeton paketinde ekstra jetonlar</li>
                    <li>Özelleştirilebilir tema renkleri</li>
                    <li>Her ay 5 adet Premium Seçkisi (ücretsiz StoryVerce Originals)</li>
                </ul>
                <a href="#" class="btn">Premium'a Geç</a>
                <div class="trial">7 gün ücretsiz deneme</div>
            </div>

            <div class="plan-card premium-plus">
                <div class="plan-name">Premium+</div>
                <div class="price">₺59,99 <small>/ay</small></div>
                <ul class="features">
                    <li>Tüm Premium avantajları</li>
                    <li>Her ay 200 Bonus Jeton</li>
                    <li>İstediğin StoryVerce Originals'leri açma hakkı</li>
                    <li>Özel tepki sticker'ları</li>
                    <li>Aylık Premium Seçkisi + daha fazla özgürlük</li>
                </ul>
                <a href="#" class="btn">Premium+'a Geç</a>
                <div class="trial">7 gün ücretsiz deneme • İlk ay bonus jetonlarla başla</div>
            </div>

        </div>

        <div class="comparison">
            <h2>Premium vs Premium+ Karşılaştırması</h2>
            <table>
                <tr>
                    <th>Özellik</th>
                    <th>Premium</th>
                    <th>Premium+</th>
                </tr>
                <tr>
                    <td>Reklamsız okuma</td>
                    <td class="check">✓</td>
                    <td class="check">✓</td>
                </tr>
                <tr>
                    <td>Çevrimdışı sınırsız</td>
                    <td class="check">✓</td>
                    <td class="check">✓</td>
                </tr>
                <tr>
                    <td>Ekstra jetonlar</td>
                    <td class="check">✓</td>
                    <td class="check">✓</td>
                </tr>
                <tr>
                    <td>Premium Seçkisi (aylık 5 ücretsiz Original)</td>
                    <td class="check">✓</td>
                    <td class="check">✓</td>
                </tr>
                <tr>
                    <td>Aylık 200 Bonus Jeton</td>
                    <td>—</td>
                    <td class="check">✓</td>
                </tr>
                <tr>
                    <td>İstediğin Originals'leri açma</td>
                    <td>—</td>
                    <td class="check">✓</td>
                </tr>
                <tr>
                    <td>Özel tema & sticker'lar</td>
                    <td class="check">✓</td>
                    <td class="check">✓</td>
                </tr>
            </table>
        </div>

    </div>

    <footer>
        <p>© 2026 StoryVerce Clone • Sadece eğitim ve eğlence amaçlı statik sayfadır</p>
    </footer>

</body>
</html>