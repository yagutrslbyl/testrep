@using Eat.ViewModels.StoryVMs
@{
    Layout = null;
}
@model CreateStoryVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create New Story | Wattpad</title>

    <link rel="stylesheet" href="~/css/reset.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/create-story.css" asp-append-version="true">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <header class="story-header">
        <div class="left">
        @*     ← <button class="btn btn--primary" asp-controller="Story" asp-action="MyStories">Add Story Info</button>
        </div> *@
            <a class="btn btn--primary" asp-controller="Story" asp-action="MyStories">
                Add Story Info
            </a>
        </div>

        <h1 contenteditable="true">Untitled Story</h1>

        <div class="right">
            <button class="btn btn--ghost">Cancel</button>
            <button type="submit" form="createForm" class="btn btn-primary">
                Start Writing
            </button>
        </div>
    </header>

    <main class="story-container">

        <!-- LEFT SIDE -->
        <div class="story-left">

            <div class="cover-upload">
                <label asp-for="CoverImage" for="coverInput">
                    <div class="cover-preview" id="coverPreview">
                        <div class="cover-placeholder">
                            <span>🖼</span>
                            <p>Add a cover</p>
                        </div>
                    </div>
                </label>
                <input asp-for="CoverImage"
                       type="file"
                       id="coverInput"
                       accept="image/*"
                       hidden
                       form="createForm">
            </div>

            <div class="story-status-card">
                <h4>Publishing</h4>
                <p>Your story is currently in draft mode.</p>
                <span class="status-badge">Draft</span>
            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="story-right">

            <form asp-action="Create" id="createForm" method="post" enctype="multipart/form-data" class="story-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                @Html.AntiForgeryToken()
                <div class="form-card">
                    <h2>Story Details</h2>

                    <label asp-for="Title" class="form-group">
                        <span>Title</span>
                        <input asp-for="Title" type="text" placeholder="Untitled Story">
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </label>

                    <label asp-for="Description" class="form-group">
                        <span>Description</span>
                        <textarea asp-for="Description" placeholder="Describe your story..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </label>

                    <label class="form-group">
                        <span>Main Characters</span>

                        <div class="inline-input">
                            <input type="text" id="characterInput" placeholder="Character name">
                            <button type="button" id="addCharacterBtn">+</button>
                        </div>

                        <div id="characterList"></div>

                        <input type="hidden" asp-for="MainCharacters" id="charactersHidden" />

                        <span asp-validation-for="MainCharacters" class="text-danger"></span>
                    </label>

                    <label asp-for="CategoryId" class="form-group">
                        <span>Category</span>
                        <select asp-for="CategoryId"
                                asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"
                                class="form-control">
                            <option value="">Select Category</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </label>

                    <label class="form-group">
                        <span>Tags</span>

                        <div class="inline-input">
                            <input type="text" id="tagInput" placeholder="Enter tag">
                            <button type="button" id="addTagBtn">+</button>
                        </div>

                        <div id="tagList"></div>

                        <!-- 🔥 əsas hissə -->
                        <input type="hidden" asp-for="Tags" id="tagsHidden" />

                        <span asp-validation-for="Tags" class="text-danger"></span>
                    </label>

                    <label class="form-group">
                        <span>Target Audience</span>
                        <select>
                            <option>Who is your primary audience?</option>
                            <option>Young Adult</option>
                            <option>Adult</option>
                            <option>Everyone</option>
                        </select>
                        
                    </label>

                    <label asp-for=Language class="form-group">
                        <span>Language</span>
                        <select asp-for="Language" class="form-control">
                            <option value="English">English</option>
                            <option value="Turkish">Turkish</option>
                        </select>
                    </label>
                    

                </div>
                <button type="submit" class="btn btn-primary">
                    Start Writing
                </button>
            </form>

        </div>

    </main>

    <script src="~/js/create-story.js"></script>
</body>
</html>
