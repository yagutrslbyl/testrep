@model Eat.ViewModels.StoryVMs.StoryDashboardVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Title</title>
    <link rel="stylesheet"
          href="~/css/story-dashboard.css"
          asp-append-version="true" />
    <!-- Font Awesome için CDN (güzel ikonlar için) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <form id="storyDetailsForm" asp-action="StoryDetails" asp-controller="Story" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div class="dashboard-container">
      

        <!-- Üst Header -->
        <header class="dashboard-header">
            <div class="header-left">
                <button asp-controller="story" asp-action="MyStories" class="back-btn">
                    <i class="fas fa-arrow-left"></i>
                </button>
                <div class="story-info">
                    <span class="edit-label">Edit Story Details</span>
                    <h1 class="story-title">@Model.Title</h1>
                </div>
            </div>

            <div class="header-actions">
                <button class="cancel-btn">Cancel</button>
           
                <button class="save-btn" type="button" id="saveHeaderBtn">Save</button>
            </div>
        </header>

        <div class="main-content">
             
            <!-- Sol Sidebar - Kapak ve Aksiyonlar -->
            <aside class="sidebar">
              
                <!-- Story Cover -->
                <div class="cover-container">
                    <div class="cover-wrapper">
                        <img src="~/uploads/stories/@Model.CoverImageUrl"
                         alt="Story Cover"
                         class="story-cover">
                           
                        <!-- Edit ikon (tam resimdeki gibi teal daire) -->
                        <div class="cover-edit-overlay">
                                <i class="fas fa-pencil-alt"></i>
                                <input type="file" name="newCover" class="cover-file-input" />
                            </div>
                    </div>
                </div>

                <!-- View as Reader Butonu -->
                <button asp-controller="story" asp-action="ReaderDetails" asp-route-id="@Model.Id" class="view-reader-btn">
                    <i class="fas fa-eye"></i>
                    View as reader
                </button>

                <!-- Share Section -->
                <div class="share-section">
                    <span class="share-label">Share</span>
                    <div class="share-icons">
                        <a href="#" class="share-icon facebook">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="#" class="share-icon twitter">
                            <i class="fab fa-x-twitter"></i>
                        </a>
                        <a href="#" class="share-icon pinterest">
                            <i class="fab fa-pinterest"></i>
                        </a>
                    </div>
                </div>
            </aside>

            <!-- Sağ İçerik Alanı -->
            <section class="content-area">

                <!-- Tabs -->
                    <div class="tabs-container">
                        <button type="button" class="tab-btn" data-tab="details">Story Details</button>
                        <button type="button" class="tab-btn active" data-tab="toc">Table of Contents</button>
                        <button type="button" class="tab-btn" data-tab="notes">Story Notes</button>
                    </div>

                <!-- Tab İçerikleri -->
                <!-- STORY DETAILS TAB -->
                <div id="details-tab" class="tab-content">
                    <div class="details-form">
                        <div class="form-group">
                            <label class="form-label">Story Title</label>
                            <input asp-for="Title" type="text"
                                   class="form-input"
                                 
                                   placeholder="Story başlığını girin...">
                        </div>

                        <div class="form-group">
                            <label asp-for=Description class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-textarea" rows="8" placeholder="Hikayenin kısa açıklamasını yazın...">
                            </textarea>
                        </div>

                        <!-- Ekstra güzel detaylar (static ama profesyonel görünüm için) -->
                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Language" class="form-label">Language</label>
                                <select asp-for="Language" class="form-select">
                                    <option value="en">English</option>
                                    <option value="tr" selected>Turkish</option>
                                </select>
                            </div>
                           
                        </div>
                    </div>
                </div>
               
                <!-- TABLE OF CONTENTS TAB (Resimdeki aktif tab) -->
                <div id="toc-tab" class="tab-content active">
                        @* <a asp-controller="Story" asp-action="StartChapter" asp-route-id="@Model.Id" class="new-part-btn">
                            New Chapter
                        </a> *@
            

                    <div class="parts-list">

                        <div class="parts-list">

                            @if (Model.Chapters != null && Model.Chapters.Any())
                            {
                                @foreach (var chapter in Model.Chapters)
                                {
                                    <div class="part-item">
                                        <div class="drag-handle">
                                            <i class="fas fa-grip-lines"></i>
                                        </div>

                                            <div class="part-info">
                                                <a asp-controller="Story"
                                                   asp-action="Write"
                                                   asp-route-storyId="@Model.Id"
                                                   asp-route-chapterId="@chapter.Id"
                                                   class="part-title-link">
                                                    <h3 class="part-title">@chapter.Title</h3>
                                                </a>
                                                <span class="published-date">
                                                    Created - @chapter.CreatedDate.ToString("MMM dd, yyyy")
                                                </span>
                                            </div>

                                            <div class="part-stats">
                                                <div class="stat">
                                                    <i class="fas fa-eye"></i>
                                                    <span>@Model.TotalViews</span>
                                                </div>
                                                <div class="stat">
                                                    <i class="fas fa-star"></i>
                                                    <span>@Model.Votes</span>
                                                </div>
                                                <div class="stat">
                                                    <i class="fas fa-comment"></i>
                                                    <span>@Model.CommentCount</span>
                                                </div>
                                            </div>

                                            <form asp-controller="Story"
                                                  asp-action="DeleteChapter"
                                                  method="post"
                                                  style="display:inline;">

                                                <input type="hidden" name="chapterId" value="@chapter.Id" />
                                                <input type="hidden" name="storyId" value="@Model.Id" />

                                                <button type="submit" class="menu-btn delete-btn"
                                                        onclick="return confirm('Are you sure you want to delete this chapter?');">
                                                    <i class="fas fa-trash"></i>
                                                </button>

                                            </form>
                                    </div>
                                }
                            }
                            else
                            {
                                <p style="opacity:0.6;">No chapters yet.</p>
                            }

                        </div>

                    </div>
                </div>

                <!-- STORY NOTES TAB -->
                <div id="notes-tab" class="tab-content">
                    <div class="notes-container">
                        <h3 class="notes-title">Story Notes</h3>
                        <textarea asp-for="Notes" class="notes-textarea" placeholder="Hikaye ile ilgili notlarınızı buraya yazın... (Karakter gelişimi, plot twist fikirleri, vs.)">
• Ana karakterin travması daha derin işlenecek
• 5. bölümde büyük revelation geliyor
• Okuyucu yorumlarından esinlenerek yeni side character eklenebilir
                        </textarea>
                    </div>
                </div>

            </section>
          
        </div>

    </div>
    </form>

    <!-- Basit Vanilla JS - Tab switching (static ama kullanışlı) -->
    <script>
        const tabButtons = document.querySelectorAll('.tab-btn');
        const tabContents = document.querySelectorAll('.tab-content');

        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                // Tüm active'leri kaldır
                tabButtons.forEach(btn => btn.classList.remove('active'));
                tabContents.forEach(content => content.classList.remove('active'));

                // Seçilen tab'ı aktif yap
                button.classList.add('active');
                const tabId = button.getAttribute('data-tab');
                document.getElementById(tabId + '-tab').classList.add('active');
            });
        });
                document.getElementById('saveHeaderBtn').addEventListener('click', function() {
            document.getElementById('storyDetailsForm').submit();
        });
    </script>
</body>
</html>
