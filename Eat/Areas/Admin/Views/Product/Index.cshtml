 <!-- Begin Page Content -->
@model List<Product>
@{
    int counter = 1;
}
<div class="container-fluid">

    <!-- Page Heading -->
    <h1 class="h3 mb-2 text-gray-800">Tables</h1>
    <p class="mb-4">
        DataTables is a third party plugin that is used to generate the demo table below.
        For more information about DataTables, please visit the <a target="_blank"
                                                                   href="https://datatables.net">official DataTables documentation</a>.
    </p>

    <!-- DataTales Example -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                Product
                <a class="btn btn-primary" asp-area="admin" asp-controller="Product" asp-action="Create">Create</a>
            </h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Id</th>

                            <th>Name</th>
                            <th>Image</th>
                            <th>Category</th>


                            <th>Update</th>
                            <th>Delete</th>

                        </tr>
                    </thead>

                   
                    <tbody>
                        @foreach (var pro in Model)
                        {
                            <tr>

                                <td>@counter</td>
                                <td>@pro.Id</td>
                                <td>@pro.Name</td>
                                <td>
                                    <img src="~/Upload/Product/@pro.Image" />
                                    
                                   </td>
                                <td>@pro.Category.Name</td>

                                <td>
                                    <a class="btn btn-warning" asp-area="admin" asp-controller="product" asp-action="update" asp-route-id="@pro.Id">Update</a>
                                </td>
                                <td>
                                    <form>
                                        <a class="btn btn-danger" asp-area="admin" asp-controller="product" asp-action="delete" asp-route-id="@pro.Id">Delete</a>

                                    </form>
                                </td>
                                @counter++;

                            </tr>
                        }



                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
<!-- /.container-fluid -->
